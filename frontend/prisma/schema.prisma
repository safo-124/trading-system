generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "esm"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// MARKET DATA
// Read-mostly tables populated by Python pipelines (swing/, swing_eu/, etc.)
// ============================================================================

enum Market {
  US
  EU
  SA
  GHANA
}

enum PredictionType {
  BACKTEST_HISTORICAL
  LIVE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model Stock {
  id           Int       @id @default(autoincrement())
  symbol       String
  market       Market
  name         String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dailyBars             DailyBar[]
  features              Feature[]
  predictions           Prediction[]
  dividendPicks         DividendPick[]
  livePredictions       LivePrediction[]
  ghanaFundamental      GhanaFundamental?
  ghanaScore            GhanaScore?
  portfolioPositions    PortfolioPosition[]
  watchlistItems        WatchlistItem[]

  @@unique([symbol, market])
  @@index([market])
}

model DailyBar {
  stockId  Int
  date     DateTime @db.Date
  open     Decimal  @db.Decimal(18, 6)
  high     Decimal  @db.Decimal(18, 6)
  low      Decimal  @db.Decimal(18, 6)
  close    Decimal  @db.Decimal(18, 6)
  volume   BigInt

  stock    Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@id([stockId, date])
  @@index([date])
}

model Feature {
  stockId                  Int
  date                     DateTime @db.Date

  // Returns at multiple horizons
  ret1d                    Float?
  ret5d                    Float?
  ret20d                   Float?
  ret60d                   Float?
  ret120d                  Float?
  logret1d                 Float?
  logret5d                 Float?
  logret20d                Float?
  logret60d                Float?
  logret120d               Float?

  // Volatility features
  vol20d                   Float?
  vol60d                   Float?
  volRegimeZ               Float?

  // Volume features
  dollarVolume             Float?
  dollarVolume20dMean      Float?
  volumeZscore20d          Float?

  // DSP features
  kalmanLogprice           Float?
  kalmanDeviation          Float?
  spectralLowFreqRatio     Float?

  // Cross-sectional ranks
  ret5dXsRank              Float?
  ret20dXsRank             Float?
  ret60dXsRank             Float?
  ret120dXsRank            Float?
  vol20dXsRank             Float?

  stock                    Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@id([stockId, date])
  @@index([date])
}

model Prediction {
  id              Int            @id @default(autoincrement())
  stockId         Int
  date            DateTime       @db.Date
  predictionType  PredictionType
  pred            Float
  fwdRet5d        Float?
  asOf            DateTime       @default(now())

  stock           Stock          @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, date])
  @@index([predictionType, asOf])
  @@index([predictionType, date])
}

model BacktestSummary {
  id                Int      @id @default(autoincrement())
  market            Market   @unique
  nDays             Int
  startDate         DateTime @db.Date
  endDate           DateTime @db.Date
  annReturnGross    Float
  annReturnNet      Float
  annVol            Float
  sharpeGross       Float
  sharpeNet         Float
  maxDrawdownNet    Float
  hitRateNet        Float
  totalReturnNet    Float
  benchmarkSymbol   String?
  benchmarkSharpe   Float?
  benchmarkReturn   Float?
  updatedAt         DateTime @updatedAt
}

// ============================================================================
// COMPUTED RESULTS
// Periodically refreshed by scheduled jobs
// ============================================================================

model DividendPick {
  id              Int      @id @default(autoincrement())
  stockId         Int
  rank            Int
  yield           Float
  payoutRatio     Float?
  divCagr5y       Float?
  consecIncreases Int?
  fcfCoverage     Float?
  safetyScore     Float
  compositeScore  Float
  generatedAt     DateTime @default(now())

  stock           Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, generatedAt])
  @@index([generatedAt, rank])
}

model LivePrediction {
  id            Int       @id @default(autoincrement())
  stockId       Int
  market        Market
  asOf          DateTime  @db.Date
  pred          Float
  close         Decimal?  @db.Decimal(18, 6)
  side          String    // "LONG" or "SHORT"
  rank          Int
  generatedAt   DateTime  @default(now())

  stock         Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, asOf, side])
  @@index([market, asOf])
  @@index([generatedAt])
}

// Ghana-specific tables — fundamentals model is different from swing markets

model GhanaFundamental {
  stockId         Int      @id
  priceGhs        Float?
  volume          Float?
  eps             Float?
  peRatio         Float?
  divPerShare     Float?
  divYield        Float?
  ret1wk          Float?
  ret4wk          Float?
  ret3mo          Float?
  ret6mo          Float?
  ret1yr          Float?
  retYtd          Float?
  recentClose     Float?
  avgVolume10d    Float?
  volProxy10d     Float?
  marketCapRaw    String?
  updatedAt       DateTime @updatedAt

  stock           Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model GhanaScore {
  stockId             Int      @id
  eligible            Boolean
  liquid              Boolean
  peIntegrityOk       Boolean
  scoreValue          Float
  scoreProfitability  Float
  scoreIncome         Float
  scoreMomentum       Float
  qualityScore        Float
  updatedAt           DateTime @updatedAt

  stock               Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

// ============================================================================
// USER DATA
// NextAuth-compatible. Snapshot semantics for portfolios.
// ============================================================================

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  hashedPassword  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  accounts        Account[]
  sessions        Session[]
  portfolios      Portfolio[]
  watchlists      Watchlist[]
}

// NextAuth Account/Session tables (required if we add OAuth in Phase 2)
// See https://authjs.dev/reference/adapter/prisma

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id            String   @id @default(cuid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier  String
  token       String   @unique
  expires     DateTime

  @@unique([identifier, token])
}

model Portfolio {
  id            String              @id @default(cuid())
  userId        String
  name          String
  market        Market
  budgetUsd     Decimal?            @db.Decimal(15, 2)
  budgetLocal   Decimal?            @db.Decimal(15, 2)
  fxRateAtSave  Float?
  fxSourceAtSave String?
  horizonYears  Int?
  riskLevel     RiskLevel?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions     PortfolioPosition[]

  @@index([userId])
  @@index([userId, createdAt])
}

model PortfolioPosition {
  id              String     @id @default(cuid())
  portfolioId     String
  stockId         Int

  // Snapshot at portfolio creation time — what the user "decided"
  shares          Int
  priceAtSaveGhs  Decimal?   @db.Decimal(18, 6)
  priceAtSaveUsd  Decimal?   @db.Decimal(18, 6)
  costAtSaveGhs   Decimal?   @db.Decimal(18, 2)
  costAtSaveUsd   Decimal?   @db.Decimal(18, 2)
  weightPctAtSave Float?
  qualityScoreAtSave Float?
  notes           String[]

  portfolio       Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock           Stock      @relation(fields: [stockId], references: [id], onDelete: Restrict)

  @@index([portfolioId])
}

model Watchlist {
  id          String          @id @default(cuid())
  userId      String
  name        String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id           String     @id @default(cuid())
  watchlistId  String
  stockId      Int
  addedAt      DateTime   @default(now())
  notes        String?

  watchlist    Watchlist  @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  stock        Stock      @relation(fields: [stockId], references: [id], onDelete: Restrict)

  @@unique([watchlistId, stockId])
  @@index([watchlistId])
}
